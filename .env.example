# Samakan dengan koneksi database yang dipakai Laravel (.env, DB_* )
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=
DB_DATABASE=db_marcom_analytics

# Kunci rahasia untuk komunikasi Laravel -> Python.
# Generate string acak, lalu salin nilai yang SAMA ke .env Laravel (ANALYTICS_API_KEY).
ANALYTICS_API_KEY=ganti-dengan-string-acak-yang-panjang
